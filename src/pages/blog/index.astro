---
import Layout from '../../layouts/Layout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { db, Post, eq } from 'astro:db';

// Fetch all posts from both sources
const filePosts = await getCollection('blog');
const dbPosts = await db.select().from(Post).where(eq(Post.status, 'published'));

// Merge and normalize posts
const allPosts = [
  ...filePosts.map((p) => ({
    slug: p.slug,
    source: 'file' as const,
    data: {
      title: p.data.title,
      description: p.data.description,
      pubDate: p.data.pubDate,
      heroImage: p.data.heroImage || null,
      article_type: p.data.article_type || null,
      readingTime: null as number | null,
    },
  })),
  ...dbPosts.map((p) => ({
    slug: p.slug,
    source: 'db' as const,
    data: {
      title: p.title,
      description: p.description,
      pubDate: p.pubDate instanceof Date ? p.pubDate : new Date(String(p.pubDate)),
      heroImage: p.heroImage || null,
      article_type: p.article_type || null,
      readingTime: p.readingTime || null,
    },
  })),
].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Collect unique types for filter chips
const typeLabels: Record<string, string> = {
  comparison: 'Vergelijking',
  review: 'Review',
  bonus: 'Bonus',
  trust: 'Vertrouwen',
  fee: 'Kosten',
  'amazon-review': 'Amazon',
  'bol-review': 'Bol.com',
  guide: 'Gids',
  news: 'Nieuws',
};

const availableTypes = [...new Set(allPosts.map(p => p.data.article_type).filter(Boolean))] as string[];
---

<Layout title="Blog - Alle artikelen" description="Alle crypto trading artikelen van ShortNews. Vergelijkingen, reviews en strategieën voor traders in Nederland en België.">

  {/* Page header */}
  <div class="blog-header">
    <div class="blog-header__inner">
      <div class="blog-header__content">
        <span class="header-badge">Blog</span>
        <h1 class="header-title">Alle artikelen</h1>
        <p class="header-subtitle">{allPosts.length} {allPosts.length === 1 ? 'artikel' : 'artikelen'} gepubliceerd</p>
      </div>
    </div>
  </div>

  {/* Toolbar: search + sort + filter */}
  <div class="toolbar-wrap">
    <div class="toolbar">
      {/* Search */}
      <div class="search-wrap">
        <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
          <circle cx="11" cy="11" r="8"/>
          <path d="M21 21l-4.35-4.35"/>
        </svg>
        <input
          id="blog-search"
          type="search"
          placeholder="Zoek artikelen…"
          class="search-input"
          aria-label="Zoek artikelen"
          autocomplete="off"
        />
        <button id="search-clear" class="search-clear" aria-label="Wis zoekopdracht" style="display:none">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>

      {/* Sort */}
      <div class="sort-wrap" role="group" aria-label="Sortering">
        <button id="sort-new" class="sort-btn sort-btn--active" data-sort="new">Nieuwste</button>
        <button id="sort-old" class="sort-btn" data-sort="old">Oudste</button>
      </div>
    </div>

    {/* Filter chips (only when article types exist) */}
    {availableTypes.length > 0 && (
      <div class="filter-chips" role="group" aria-label="Filter op type">
        <button class="chip chip--active" data-type="all">Alles</button>
        {availableTypes.map(type => (
          <button class="chip" data-type={type}>
            {typeLabels[type] || type}
          </button>
        ))}
      </div>
    )}
  </div>

  {/* Results count + empty state */}
  <div class="results-bar">
    <div class="results-bar__inner">
      <span id="results-count" class="results-count"></span>
    </div>
  </div>

  {/* Article grid */}
  <section class="grid-section">
    <div class="grid-inner">
      <div id="posts-grid" class="posts-grid">
        {allPosts.map((post) => (
          <ArticleCard 
            post={post} 
            variant="default" 
            showExcerpt={true}
            data-title={post.data.title.toLowerCase()}
            data-description={post.data.description?.toLowerCase() || ''}
            data-type={post.data.article_type || 'none'}
            data-date={post.data.pubDate.valueOf()}
          />
        ))}
      </div>

      {/* Empty state */}
      <div id="empty-state" class="empty-state" style="display:none">
        <div class="empty-state__icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="11" cy="11" r="8"/>
            <path d="M21 21l-4.35-4.35"/>
          </svg>
        </div>
        <p class="empty-state__title">Geen artikelen gevonden</p>
        <p class="empty-state__text">Voor <strong id="empty-query"></strong></p>
        <button id="empty-reset" class="empty-reset">Wis alle filters</button>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Header ───────────────────────────────────────────────── */
  .blog-header {
    padding: 2.5rem 1rem 1.5rem;
  }
  
  @media (min-width: 768px) {
    .blog-header {
      padding: 3.5rem 1.5rem 2rem;
    }
  }
  
  .blog-header__inner {
    max-width: 80rem;
    margin: 0 auto;
  }
  
  .blog-header__content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .header-badge {
    display: inline-flex;
    align-self: flex-start;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }
  
  .header-title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-navy);
    letter-spacing: -0.02em;
    margin: 0;
  }
  
  @media (min-width: 768px) {
    .header-title {
      font-size: 2.5rem;
    }
  }
  
  .header-subtitle {
    font-size: 0.9375rem;
    color: var(--text-muted);
    margin: 0;
  }

  /* ── Toolbar ─────────────────────────────────────────────── */
  .toolbar-wrap {
    position: sticky;
    top: 57px;
    z-index: 40;
    padding: 1rem 1rem 0;
    background: var(--bg-main);
    background-image: radial-gradient(circle, var(--dot-color) var(--dot-size), transparent var(--dot-size));
    background-size: var(--dot-spacing) var(--dot-spacing);
  }
  
  @media (min-width: 768px) {
    .toolbar-wrap {
      padding: 1rem 1.5rem 0;
      top: 61px;
    }
  }

  .toolbar {
    max-width: 80rem;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 0.75rem;
    box-shadow: 0 1px 4px rgba(0,0,0,0.05);
  }

  /* Search */
  .search-wrap {
    position: relative;
    flex: 1 1 200px;
    display: flex;
    align-items: center;
  }

  .search-icon {
    position: absolute;
    left: 0.875rem;
    color: var(--text-muted);
    pointer-events: none;
    flex-shrink: 0;
  }

  .search-input {
    width: 100%;
    padding: 0.625rem 2.5rem 0.625rem 2.5rem;
    border: 1px solid transparent;
    border-radius: 8px;
    background: transparent;
    font-size: 0.9375rem;
    font-family: inherit;
    color: var(--color-navy);
    outline: none;
    transition: border-color 0.15s, background 0.15s;
  }

  .search-input::placeholder { color: var(--text-muted); }

  .search-input:focus {
    border-color: var(--border-color);
    background: var(--bg-main);
  }

  /* clear ✕ button */
  .search-clear {
    position: absolute;
    right: 0.75rem;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-muted);
    padding: 4px;
    display: flex;
    align-items: center;
    border-radius: 4px;
    transition: color 0.15s, background 0.15s;
  }
  
  .search-clear:hover { 
    color: var(--color-navy); 
    background: rgba(27, 45, 79, 0.06);
  }

  /* Sort */
  .sort-wrap {
    display: flex;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  .sort-btn {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    font-family: inherit;
    border-radius: 8px;
    border: 1px solid transparent;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.12s;
    white-space: nowrap;
  }

  .sort-btn:hover { color: var(--color-navy); background: var(--bg-main); }

  .sort-btn--active {
    background: var(--color-navy);
    color: var(--color-cream);
    border-color: var(--color-navy);
  }

  /* Filter chips */
  .filter-chips {
    max-width: 80rem;
    margin: 0.75rem auto 0;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding-bottom: 0.5rem;
  }

  .chip {
    padding: 0.5rem 1rem;
    font-size: 0.8125rem;
    font-weight: 600;
    font-family: inherit;
    border-radius: 100px;
    border: 1px solid var(--border-color);
    background: var(--bg-card);
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.12s;
    white-space: nowrap;
  }

  .chip:hover { border-color: var(--color-navy); color: var(--color-navy); }

  .chip--active {
    background: var(--color-navy);
    color: var(--color-cream);
    border-color: var(--color-navy);
  }

  /* ── Results bar ─────────────────────────────────────────── */
  .results-bar {
    padding: 0.75rem 1rem 0;
  }
  
  @media (min-width: 768px) {
    .results-bar {
      padding: 0.75rem 1.5rem 0;
    }
  }
  
  .results-bar__inner {
    max-width: 80rem;
    margin: 0 auto;
  }
  
  .results-count {
    font-size: 0.8125rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  /* ── Grid ────────────────────────────────────────────────── */
  .grid-section {
    padding: 1rem 1rem 4rem;
  }
  
  @media (min-width: 768px) {
    .grid-section {
      padding: 1rem 1.5rem 5rem;
    }
  }
  
  .grid-inner {
    max-width: 80rem;
    margin: 0 auto;
  }

  .posts-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .posts-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .posts-grid { grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  }

  /* ── Empty state ─────────────────────────────────────────── */
  .empty-state {
    text-align: center;
    padding: 5rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-muted);
  }

  .empty-state__icon {
    opacity: 0.3;
    margin-bottom: 0.5rem;
  }
  
  .empty-state__title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-navy);
    margin: 0;
  }
  
  .empty-state__text {
    font-size: 0.9375rem;
    margin: 0;
  }
  
  .empty-state strong { 
    color: var(--color-navy); 
    font-weight: 600;
  }

  .empty-reset {
    margin-top: 0.75rem;
    padding: 0.625rem 1.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    font-family: inherit;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background: var(--bg-card);
    color: var(--color-navy);
    cursor: pointer;
    transition: all 0.15s;
  }
  
  .empty-reset:hover { 
    background: var(--color-navy); 
    color: var(--color-cream); 
    border-color: var(--color-navy);
  }

  /* ── Hidden card (filtered out) ─────────────────────────── */
  :global(.article-card[hidden]) { display: none; }
  
  /* Dark mode overrides */
  html.dark .header-title,
  html.dark .empty-state__title,
  html.dark .empty-state strong {
    color: var(--text-main);
  }
  
  html.dark .sort-btn--active,
  html.dark .chip--active {
    background: var(--text-main);
    color: var(--bg-main);
    border-color: var(--text-main);
  }
  
  html.dark .sort-btn:hover {
    color: var(--text-main);
  }
  
  html.dark .chip:hover,
  html.dark .sort-btn:hover {
    border-color: var(--text-main);
    color: var(--text-main);
  }
</style>

<script>
  const searchInput  = document.getElementById('blog-search')   as HTMLInputElement;
  const searchClear  = document.getElementById('search-clear')  as HTMLButtonElement;
  const sortNewBtn   = document.getElementById('sort-new')      as HTMLButtonElement;
  const sortOldBtn   = document.getElementById('sort-old')      as HTMLButtonElement;
  const grid         = document.getElementById('posts-grid')    as HTMLElement;
  const emptyState   = document.getElementById('empty-state')   as HTMLElement;
  const emptyQuery   = document.getElementById('empty-query')   as HTMLElement;
  const emptyReset   = document.getElementById('empty-reset')   as HTMLButtonElement;
  const resultsCount = document.getElementById('results-count') as HTMLElement;
  const chipBtns     = document.querySelectorAll<HTMLButtonElement>('.chip');

  const allCards = Array.from(
    grid.querySelectorAll<HTMLElement>(':scope > .article-card')
  );

  let query       = '';
  let activeType  = 'all';
  let sortDir     = 'new';

  // ── Render ──────────────────────────────────────────────────
  function render() {
    const q = query.trim().toLowerCase();

    let visible: HTMLElement[] = [];

    allCards.forEach(card => {
      const titleMatch = card.dataset.title?.includes(q) ?? true;
      const descMatch  = card.dataset.description?.includes(q) ?? true;
      const typeMatch  = activeType === 'all' || card.dataset.type === activeType;
      const show       = (titleMatch || descMatch) && typeMatch;

      card.hidden = !show;
      if (show) visible.push(card);
    });

    // Sort visible cards in DOM
    visible
      .sort((a, b) => {
        const da = Number(a.dataset.date);
        const db = Number(b.dataset.date);
        return sortDir === 'new' ? db - da : da - db;
      })
      .forEach(card => grid.appendChild(card));

    // Results count
    const total = allCards.length;
    if (q || activeType !== 'all') {
      resultsCount.textContent = `${visible.length} van ${total} artikelen`;
    } else {
      resultsCount.textContent = '';
    }

    // Empty state
    const isEmpty = visible.length === 0;
    emptyState.style.display = isEmpty ? 'flex' : 'none';
    if (isEmpty && q) emptyQuery.textContent = `"${q}"`;
    else if (isEmpty) emptyQuery.textContent = 'deze filter';
  }

  // ── Events ──────────────────────────────────────────────────
  searchInput?.addEventListener('input', () => {
    query = searchInput.value;
    searchClear.style.display = query ? 'flex' : 'none';
    render();
  });

  searchClear?.addEventListener('click', () => {
    searchInput.value = '';
    query = '';
    searchClear.style.display = 'none';
    searchInput.focus();
    render();
  });

  sortNewBtn?.addEventListener('click', () => {
    sortDir = 'new';
    sortNewBtn.classList.add('sort-btn--active');
    sortOldBtn.classList.remove('sort-btn--active');
    render();
  });

  sortOldBtn?.addEventListener('click', () => {
    sortDir = 'old';
    sortOldBtn.classList.add('sort-btn--active');
    sortNewBtn.classList.remove('sort-btn--active');
    render();
  });

  chipBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activeType = btn.dataset.type || 'all';
      chipBtns.forEach(b => b.classList.toggle('chip--active', b === btn));
      render();
    });
  });

  emptyReset?.addEventListener('click', () => {
    query = '';
    activeType = 'all';
    sortDir = 'new';
    searchInput.value = '';
    searchClear.style.display = 'none';
    chipBtns.forEach(b => b.classList.toggle('chip--active', b.dataset.type === 'all'));
    sortNewBtn.classList.add('sort-btn--active');
    sortOldBtn.classList.remove('sort-btn--active');
    render();
  });

  // Initial count
  render();
</script>
